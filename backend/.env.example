# Claim360 Backend Environment Configuration
# Copy this to backend/.env and fill in your values

# ── Application ──────────────────────────────────────────────────
APP_NAME=Claim360
SECRET_KEY=your-very-strong-secret-key-change-this-in-production

# ── Database (PostgreSQL) ─────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/claim360
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/claim360

# ── Redis (for Celery task queue) ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Google OAuth 2.0 ─────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Required scopes: gmail.send, gmail.readonly, openid, email, profile
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# For local dev: http://localhost:8000/api/auth/oauth/callback
# For production: https://your-vercel-domain.vercel.app/api/auth/oauth/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/callback

# ── File Storage ──────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_ATTACHMENT_SIZE_MB=25

# ── Email Sending ─────────────────────────────────────────────────
SEND_DELAY_SECONDS=3

# ── Tracking (must be publicly accessible URL for open tracking) ──
# Local dev: use ngrok, e.g. https://abc123.ngrok.io
# Production: your Vercel deployment URL
BASE_URL=http://localhost:8000

# ── Admin Account (auto-created on first run) ─────────────────────
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-this-strong-password

# ── Token Expiry ──────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Frontend (for OAuth redirect after Google login) ──────────────────────────
# Local dev:      http://localhost:3000
# Production:     https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:3000
